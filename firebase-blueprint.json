{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and activity history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "favorites": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of product IDs marked as favorites"
        },
        "clickHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "platform": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Affiliate product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "discount": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "platform": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "affiliateUrl": { "type": "string", "format": "uri" }
      },
      "required": ["title", "price", "platform", "category", "affiliateUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product document"
    }
  }
}
